* text=auto eol=lf
*.php diff=php

# Keep distributed packages lean — exclude dev-only paths from `git archive` / dist.
/.github            export-ignore
/docs               export-ignore
/tests              export-ignore
/workbench          export-ignore
/.editorconfig      export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/phpstan.neon       export-ignore
/phpstan-baseline.neon export-ignore
/pint.json          export-ignore
/rector.php         export-ignore
/phpunit.xml        export-ignore
/infection.json5    export-ignore
/testbench.yaml     export-ignore
/cliff.toml         export-ignore
/package.json       export-ignore
/package-lock.json  export-ignore
/CONTRIBUTING.md    export-ignore
/DEVELOPMENT.md     export-ignore
/RELEASING.md       export-ignore
/UPGRADING.md       export-ignore

# AI / dev tooling — never ship in the Composer dist tarball.
/AGENTS.md          export-ignore
/CLAUDE.md          export-ignore
/AI-OPTIMIZATION.md export-ignore
/skills-lock.json   export-ignore
/.cursorrules       export-ignore
/.mcp.json          export-ignore
/.mcp.json.example  export-ignore
/.claude            export-ignore
/.serena            export-ignore
/.swissknifeman     export-ignore
/ideas              export-ignore
