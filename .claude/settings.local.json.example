{
  "permissions": {
    "allow": [
      "Bash(composer *)",
      "Bash(vendor/bin/pest *)",
      "Bash(vendor/bin/phpstan *)",
      "Bash(vendor/bin/pint *)",
      "Bash(vendor/bin/rector *)",
      "Bash(./vendor/bin/pest *)",
      "Bash(php vendor/bin/pest *)",
      "Bash(php vendor/bin/phpstan *)",
      "Bash(<ABS_PATH_TO_PROJECT>/vendor/bin/pest *)",
      "Bash(<ABS_PATH_TO_PROJECT>/vendor/bin/phpstan *)",
      "Bash(php *)",
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(grep *)",
      "Bash(sed -n *)",
      "Bash(xargs *)",
      "Bash(DB_CONNECTION=sqlite *)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(gh repo view *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln -s *)",
      "Bash(chmod +x *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(xargs rg *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(php -l *)",
      "Bash(php -r *)",
      "Bash(php -v)",
      "Bash(composer install *)",
      "Bash(composer update *)",
      "Bash(composer require *)",
      "Bash(composer remove *)",
      "Bash(composer dump-autoload *)",
      "Bash(composer run *)",
      "Bash(composer test *)",
      "Bash(composer validate *)",
      "Bash(composer show *)",
      "Bash(vendor/bin/phpunit *)",
      "Bash(vendor/bin/infection *)",
      "Bash(./vendor/bin/phpunit *)",
      "Bash(./vendor/bin/pint *)",
      "Bash(./vendor/bin/phpstan *)",
      "Bash(./vendor/bin/rector *)",
      "Bash(node *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm exec *)",
      "Bash(npm ls *)",
      "Bash(npm outdated *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(tsc *)",
      "Bash(vitest *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "mcp__context7__query-docs",
      "Workflow",
      "Agent",
      "TodoWrite"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(sudo *)",
      "Read(node_modules/**)",
      "Read(**/*.lock)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.next/**)",
      "Read(coverage/**)",
      "Read(**/*.min.js)",
      "Read(**/*.min.css)",
      "Read(~/.claude/logs/**)",
      "Read(**/CHANGELOG.md)",
      "Read(**/skills.json)",
      "Read(**/package-lock.json)",
      "Read(**/composer.lock)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)",
      "Bash(chmod -R *)",
      "Bash(chown *)",
      "Bash(npm publish *)",
      "Bash(npm version *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-approve/auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-approve/auto-approve.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "swissknifeman": {
      "source": {
        "source": "directory",
        "path": "<ABS_PATH_TO_SWISSKNIFEMAN>"
      }
    }
  },
  "enabledPlugins": {
    "task@swissknifeman": true,
    "core@swissknifeman": true,
    "devops@swissknifeman": true,
    "laravel-testing@swissknifeman": true,
    "oss-dev@swissknifeman": true,
    "php@swissknifeman": true,
    "php-packages@swissknifeman": true,
    "quality@swissknifeman": true,
    "system@swissknifeman": true
  },
  "outputStyle": "lean"
}
