{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "primary": {
      "$value": "#3B82F6",
      "$type": "color",
      "$description": "figma:variable/Primary/Blue-500"
    },
    "surface": {
      "default": { "$value": "#FFFFFF", "$type": "color", "$description": "figma:variable/Surface/Default (mode:light)" },
      "elevated": { "$value": "#F8FAFC", "$type": "color" }
    }
  },
  "spacing": {
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "24px", "$type": "dimension" },
    "xl": { "$value": "32px", "$type": "dimension" }
  },
  "typography": {
    "heading-1": {
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "32px",
        "fontWeight": 700,
        "lineHeight": "40px"
      },
      "$type": "typography"
    }
  },
  "border-radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "_modes": {
    "$description": "Multi-mode (Variable Modes): для каждого мода — отдельное значение токена. Маппится в .dark / data-theme на фронте и в ThemeData(brightness) во Flutter.",
    "color.primary": { "light": "#3B82F6", "dark": "#60A5FA" },
    "color.surface.default": { "light": "#FFFFFF", "dark": "#0F172A" }
  }
}
