# Source: anonymized production Laravel project
# Всё-в-одном образ: PHP-FPM + Nginx (serversideup), production-ready.
# Один образ для app/queue/scheduler/reverb/vite — различается только command в compose.
FROM serversideup/php:8.3-fpm-nginx

USER root

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    libicu-dev \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    libmagickwand-dev \
    libpq-dev \
    libzip-dev \
    # Node.js + pnpm — если фронтенд (vite) работает из этого же образа
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g pnpm \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install intl bcmath gd exif sockets pcntl pdo_pgsql pgsql zip \
    && pecl install imagick \
    && docker-php-ext-enable imagick \
    && if ! php -m | grep -qi '^redis$'; then pecl install redis && docker-php-ext-enable redis; fi \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /var/www/html

# Каталоги Laravel, которые должны существовать до первого запуска
RUN mkdir -p storage/framework/sessions \
    storage/framework/views \
    storage/framework/cache \
    bootstrap/cache \
    && chown -R www-data:www-data /var/www/html

# Кастомный nginx-конфиг (root public/, fastcgi на 127.0.0.1:9000, порт 8080)
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf

# Хук entrypoint.d: автоматически выполняется при старте контейнера (см. entrypoint-hook.sh)
COPY docker/php/entrypoint.d/20-init-media-permissions.sh /etc/entrypoint.d/20-init-media-permissions.sh
RUN chmod +x /etc/entrypoint.d/20-init-media-permissions.sh

USER www-data

# Healthcheck вешается в docker-compose на Laravel-эндпоинт /up:
#   test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8080/up >/dev/null || exit 1"]
#   interval: 10s / timeout: 5s / retries: 5 / start_period: 40s
