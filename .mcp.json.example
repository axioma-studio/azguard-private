{
  "mcpServers": {
    "maind": {
      "command": "${MAIND_BIN:-maind}",
      "args": [
        "mcp",
        "--scope",
        "project:azguard"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "<ABS_PATH_TO_PROJECT>",
        "--enable-web-dashboard",
        "false"
      ]
    },
    "perplexity-web": {
      "command": "${PERPLEXITY_WEB_MCP_BIN:-<ABS_PATH_TO_PERPLEXITY_WEB_MCP>/start.sh}",
      "args": [
        "--pool=default"
      ]
    }
  }
}
