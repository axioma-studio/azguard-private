{
    "$schema": "https://infection.github.io/schema.json",
    "source": {
        "directories": [
            "packages/core/src"
        ],
        "excludes": [
            "Commands",
            "Facades"
        ]
    },
    "logs": {
        "text": "infection.log",
        "html": "infection.html",
        "summary": true
    },
    "minMsi": 70,
    "minCoveredMsi": 80,
    "testFramework": "pest",
    "mutators": {
        "@default": true
    }
}
