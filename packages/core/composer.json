{
    "name": "axioma-studio/azguard-core",
    "description": "Code-first role-based access control and permissions for Laravel — panels, pluggable grant sources, and a typed permission catalog.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rbac",
        "permissions",
        "roles",
        "authorization",
        "access-control",
        "acl",
        "gate"
    ],
    "homepage": "https://github.com/axioma-studio/azguard",
    "authors": [
        {
            "name": "Dmitry Vostrikov",
            "email": "dv.vostrikov@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/axioma-studio/azguard/issues",
        "source": "https://github.com/axioma-studio/azguard"
    },
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        },
        "laravel": {
            "providers": [
                "AzGuard\\AzGuardServiceProvider"
            ]
        }
    }
}
