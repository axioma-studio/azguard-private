<?php

declare(strict_types=1);

namespace {{ namespace }};

use {{ namespace }}\{{ domain }}\Permissions\{{ domain }}Permission;
use AzGuard\PanelProvider;
use AzGuard\Support\Panel;

class {{ panel }}GuardPanelProvider extends PanelProvider
{
    public function panel(Panel $panel): Panel
    {
        return $panel
            ->id('{{ panelId }}')
            ->path('{{ panelId }}')
            ->permissionEnums([
                {{ domain }}Permission::class,
            ]);
    }
}
