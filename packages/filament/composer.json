{
    "name": "axioma-studio/azguard-filament",
    "description": "Filament admin UI for AzGuard — config-driven, zero-boilerplate resource permissions plus role and direct-grant management (Filament 4 and 5).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "rbac",
        "permissions",
        "roles",
        "authorization",
        "admin"
    ],
    "homepage": "https://github.com/axioma-studio/azguard",
    "authors": [
        {
            "name": "Dmitry Vostrikov",
            "email": "dv.vostrikov@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/axioma-studio/azguard/issues",
        "source": "https://github.com/axioma-studio/azguard"
    },
    "require": {
        "php": "^8.3",
        "axioma-studio/azguard-core": "*",
        "filament/filament": "^4.0 || ^5.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\Filament\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AzGuard\\Filament\\AzGuardFilamentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
