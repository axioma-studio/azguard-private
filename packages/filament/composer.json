{
    "name": "azguard/filament",
    "description": "Filament bridge for AzGuard permissions",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AzGuard\\Filament\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AzGuard\\Filament\\FilamentServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "azguard/azguard": "@dev",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
