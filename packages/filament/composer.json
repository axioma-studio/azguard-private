{
    "name": "axioma-studio/azguard-filament",
    "description": "Filament UI for AzGuard — roles, permissions, direct grants management (supports Filament 4 and 5)",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "axioma-studio/azguard-core": "*",
        "filament/filament": "^4.0 || ^5.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\Filament\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AzGuard\\Filament\\AzGuardFilamentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
