{
    "name": "axioma-studio/azguard-filament",
    "description": "Filament 5 admin UI for AzGuard — config-driven, zero-boilerplate resource permissions plus role and direct-grant management.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "rbac",
        "permissions",
        "roles",
        "authorization",
        "admin"
    ],
    "homepage": "https://github.com/axioma-studio/azguard",
    "authors": [
        {
            "name": "Dmitry Vostrikov",
            "email": "dv.vostrikov@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/axioma-studio/azguard/issues",
        "source": "https://github.com/axioma-studio/azguard"
    },
    "require": {
        "php": "^8.3",
        "axioma-studio/azguard-core": "^0.1",
        "filament/filament": "^5.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\Filament\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AzGuard\\Filament\\AzGuardFilamentServiceProvider"
            ]
        }
    }
}
