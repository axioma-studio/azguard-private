{
    "name": "axioma-studio/azguard-filament",
    "description": "Filament v3 UI for AzGuard — roles, permissions, direct grants management",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "axioma-studio/azguard-core": "*",
        "filament/filament": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\Filament\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AzGuard\\Filament\\AzGuardFilamentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
