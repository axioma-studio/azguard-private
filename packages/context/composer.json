{
    "name": "axioma-studio/azguard-context",
    "description": "Multi-workspace / multi-site authorization context for AzGuard (opt-in)",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "axioma-studio/azguard-core": "*",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\Context\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AzGuard\\Context\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AzGuard\\Context\\AzGuardContextServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
