{
    "name": "axioma-studio/azguard-context",
    "description": "Multi-workspace / multi-site authorization context for AzGuard — context-scoped roles and pluggable merge strategies (opt-in).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rbac",
        "permissions",
        "multi-tenancy",
        "workspace",
        "authorization"
    ],
    "homepage": "https://github.com/axioma-studio/azguard",
    "authors": [
        {
            "name": "Dmitry Vostrikov",
            "email": "dv.vostrikov@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/axioma-studio/azguard/issues",
        "source": "https://github.com/axioma-studio/azguard"
    },
    "require": {
        "php": "^8.3",
        "axioma-studio/azguard-core": "^0.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "AzGuard\\Context\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        },
        "laravel": {
            "providers": [
                "AzGuard\\Context\\AzGuardContextServiceProvider"
            ]
        }
    }
}
