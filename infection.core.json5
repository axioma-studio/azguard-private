{
    "$schema": "https://infection.github.io/schema.json",
    "source": {
        "directories": [
            "packages/core/src"
        ],
        "excludes": [
            "Commands",
            "Facades"
        ]
    },
    "logs": {
        "text": "build/infection/core.log",
        "html": "build/infection/core.html",
        "summary": "build/infection/core-summary.log"
    },
    "minMsi": 70,
    "minCoveredMsi": 80,
    "testFramework": "phpunit",
    "mutators": {
        "@default": true
    }
}
