{
    "name": "azguard/azguard-monorepo",
    "private": true,
    "require": {
        "php": "^8.3",
        "azguard/azguard": "@dev",
        "axioma-studio/azguard-filament": "@dev",
        "axioma-studio/azguard-context": "@dev"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "rector/rector": "^2.0",
        "pestphp/pest": "^4.7",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "infection/infection": "^0.33"
    },
    "autoload-dev": {
        "psr-4": {
            "AzGuard\\Tests\\": "tests/",
            "AzGuard\\Tests\\Stubs\\": "tests/Stubs/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=80",
        "test:unit": "vendor/bin/pest tests/Unit",
        "test:feature": "vendor/bin/pest tests/Feature",
        "lint": "vendor/bin/pint",
        "lint:check": "vendor/bin/pint --test",
        "refactor": "vendor/bin/rector process",
        "refactor:check": "vendor/bin/rector process --dry-run",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=256M",
        "mutate": "vendor/bin/infection --threads=4"
    }
}
